<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My iOS App</title>

  <style>
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, sans-serif;
      background: #0d1117;
      color: #e6edf3;
      text-align: center;
    }

    .container {
      max-width: 900px;
      margin: auto;
      padding: 40px 20px;
    }

    h1 {
      font-size: 2.5rem;
      margin-bottom: 10px;
    }

    p {
      color: #9da7b3;
      line-height: 1.6;
    }

    .hero {
      margin-top: 60px;
    }

    .app-icon {
      width: 120px;
      height: 120px;
      border-radius: 25px;
      background: #161b22;
      margin: 0 auto 20px;
    }

    .btn {
      display: inline-block;
      margin-top: 20px;
      padding: 12px 20px;
      background: #238636;
      color: white;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 600;
    }

    .btn:hover {
      background: #2ea043;
    }

    .section {
      margin-top: 80px;
    }

    .features {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin-top: 30px;
    }

    .card {
      background: #161b22;
      padding: 20px;
      border-radius: 12px;
      border: 1px solid #30363d;
      text-align: left;
    }

    footer {
      margin-top: 80px;
      padding: 20px;
      font-size: 0.9rem;
      color: #6e7681;
    }
  </style>
</head>
<body>

  <div class="container">

    <div class="hero">
      <div class="app-icon"></div>
      <h1>My iOS App</h1>
      <p>A simple, powerful app designed for everyday use.</p>
      <a href="#" class="btn">Download on the App Store</a>
    </div>

    <div class="section">
      <h2>Features</h2>
      <div class="features">
        <div class="card">
          <h3>Fast</h3>
          <p>Optimized performance for a smooth experience.</p>
        </div>
        <div class="card">
          <h3>Simple</h3>
          <p>Clean design that is easy to use.</p>
        </div>
        <div class="card">
          <h3>Secure</h3>
          <p>Your data stays private and protected.</p>
        </div>
      </div>
    </div>

    <div class="section">
      <h2>Screenshots</h2>
      <p>Add app screenshots here.</p>
    </div>

    <footer>
      <p>© 2026 My App • Privacy Policy • Contact</p>
    </footer>

  </div>

</body>
</html>
